---
---

<div class="fixed inset-0 pointer-events-none z-[1]" aria-hidden="true">
  <span
    class="shooting-star interval-30"
    style="--top: 8%; --start-x: -5%; --duration: 30s; --delay: 0s; --length: 80px; --angle: -42deg;"
  ></span>
  <span
    class="shooting-star interval-45"
    style="--top: 35%; --start-x: -5%; --duration: 45s; --delay: 3s; --length: 70px; --angle: -38deg;"
  ></span>
  <span
    class="shooting-star interval-60"
    style="--top: 65%; --start-x: -5%; --duration: 60s; --delay: 6s; --length: 90px; --angle: -48deg;"
  ></span>
</div>

<style>
  @keyframes shoot-star-30 {
    0% {
      transform: translate(0, 0) rotate(var(--angle));
      opacity: 0;
    }
    1% {
      opacity: 1;
    }
    6.67% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 1;
    }
    7.67% {
      opacity: 0;
    }
    100% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 0;
    }
  }

  @keyframes shoot-star-45 {
    0% {
      transform: translate(0, 0) rotate(var(--angle));
      opacity: 0;
    }
    0.67% {
      opacity: 1;
    }
    4.44% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 1;
    }
    5.11% {
      opacity: 0;
    }
    100% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 0;
    }
  }

  @keyframes shoot-star-60 {
    0% {
      transform: translate(0, 0) rotate(var(--angle));
      opacity: 0;
    }
    0.5% {
      opacity: 1;
    }
    3.33% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 1;
    }
    3.83% {
      opacity: 0;
    }
    100% {
      transform: translate(140vw, 140vh) rotate(var(--angle));
      opacity: 0;
    }
  }

  .shooting-star {
    position: absolute;
    top: var(--top);
    left: var(--start-x);
    width: var(--length);
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 255, 255, 1) 100%
    );
    box-shadow: 0 0 10px 2px rgba(255, 255, 255, 0.4);
    opacity: 0;
    will-change: transform, opacity;
  }

  .shooting-star::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translate(50%, -50%);
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: #ffffff;
    box-shadow:
      0 0 10px 4px rgba(255, 255, 255, 1),
      0 0 24px 10px rgba(255, 255, 255, 0.5);
  }

  .shooting-star.interval-30 {
    animation: shoot-star-30 30s linear var(--delay) infinite;
  }

  .shooting-star.interval-45 {
    animation: shoot-star-45 45s linear var(--delay) infinite;
  }

  .shooting-star.interval-60 {
    animation: shoot-star-60 60s linear var(--delay) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .shooting-star {
      animation: none;
    }
  }
</style>
