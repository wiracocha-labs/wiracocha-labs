---
export interface Props {
  phase: string
  title: string
  status: string
  badgeVariant: 'accent' | 'primary' | 'secondary'
  description: string
  isLast?: boolean
}

const { phase, title, status, badgeVariant, description, isLast = false } = Astro.props

const badgeClasses: Record<string, string> = {
  accent: 'badge-accent',
  primary: 'badge-primary',
  secondary: 'badge-secondary',
}
---

<li class="relative pl-10 md:pl-14">
  <span
    class="absolute left-2 md:left-4 top-1.5 w-4 h-4 rounded-full bg-brand border-4 border-primary"
    aria-hidden="true"
  ></span>
  {!isLast && <span class="absolute left-[0.6875rem] md:left-[1.1875rem] top-6 bottom-0 w-0.5 bg-brand-20" aria-hidden="true"></span>}
  <div class="pb-10">
    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 mb-2">
      <h3 class="text-lg font-semibold text-text-primary">{title}</h3>
      <span class={`badge ${badgeClasses[badgeVariant]} w-fit`}>{status}</span>
    </div>
    <p class="text-text-primary/80 max-w-3xl">{description}</p>
  </div>
</li>
